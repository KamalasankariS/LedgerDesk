# Database
DATABASE_URL=postgresql+asyncpg://ledgerdesk:ledgerdesk_dev@localhost:5433/ledgerdesk
DATABASE_URL_SYNC=postgresql://ledgerdesk:ledgerdesk_dev@localhost:5433/ledgerdesk

# Redis
REDIS_URL=redis://localhost:6379/0

# LLM Provider (OpenAI-compatible)
OPENAI_API_KEY=your-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o

# App
LOG_LEVEL=INFO
ENVIRONMENT=development
SECRET_KEY=change-me-to-a-random-secret

# CORS (comma-separated origins)
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]

# Demo user IDs (for MVP without full auth flow)
DEMO_USER_ID=00000000-0000-0000-0000-000000000001
DEMO_ANALYST_ID=00000000-0000-0000-0000-000000000002
